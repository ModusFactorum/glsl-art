float wavePattern(vec2 p, float freq, float phase) { return sin(dot(p, vec2(freq)) + iTime * phase); } void mainImage(out vec4 fragColor, in vec2 fragCoord) { vec2 uv = (fragCoord - iResolution.xy / 2.0) / min(iResolution.x, iResolution.y); float wave1 = wavePattern(uv * 5.0, 3.0, 2.0); float wave2 = wavePattern(rotate2d(iTime * 0.5) * uv * 7.0, 4.0, 1.5); float moire = abs(wave1 - wave2); vec3 color = hsv2rgb(vec3(moire + iTime * 0.1, 1.0, 1.0)); fragColor = vec4(color, 1.0); }
